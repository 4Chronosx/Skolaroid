generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String         @id @default(uuid()) @db.Uuid
  studentId      String         @unique @db.VarChar(50)
  email          String         @unique @db.VarChar(255)
  firstName      String         @db.VarChar(100)
  lastName       String         @db.VarChar(100)
  status         Status         @default(STUDENT)
  role           UserRole       @default(USER)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  programBatchId    String         @db.Uuid
  memories          Memory[]
  votes             MemoryVote[]
  comments          MemoryComment[]
  groups            PrivateGroup[] @relation("GroupMembers")
  createdGroups     PrivateGroup[] @relation("GroupCreator")
  programBatch      ProgramBatch   @relation(fields: [programBatchId], references: [id])
  sentInvitations   Invitation[]   @relation("SentInvitations")

  @@index([email])
  @@index([studentId])
  @@index([programBatchId])
  @@index([status])
  @@index([deletedAt])
  @@index([firstName, lastName])
}

model Program {
  name           String         @db.VarChar(200)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  description    String?
  id             String         @id @default(uuid()) @db.Uuid
  programBatches ProgramBatch[]

  @@index([name])
}

model Batch {
  year           Int            @unique @db.SmallInt
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  id             String         @id @default(uuid()) @db.Uuid
  programBatches ProgramBatch[]

  @@index([year])
}

model ProgramBatch {
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  id        String   @id @default(uuid()) @db.Uuid
  programId String   @db.Uuid
  batchId   String   @db.Uuid
  memories  Memory[]
  batch     Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  students  User[]

  @@unique([programId, batchId])
  @@index([programId])
  @@index([batchId])
}

model Memory {
  id             String           @id @default(uuid()) @db.Uuid
  title          String           @db.VarChar(255)
  description    String?
  mediaURL       String?          @db.VarChar(2048)
  uploadDate     DateTime         @default(now())
  visibility     MemoryVisibility @default(PUBLIC)
  
  // Relations
  tags           Tag[]            @relation("MemoryTags")
  votes          MemoryVote[]
  comments       MemoryComment[]

  // Private group (required when visibility = GROUP_ONLY)
  privateGroupId String?          @db.Uuid
  privateGroup   PrivateGroup?    @relation(fields: [privateGroupId], references: [id], onDelete: Restrict)
  
  // Creator (nullable to preserve memories if user deleted)
  creatorId      String?          @db.Uuid
  locationId     String           @db.Uuid
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?
  isArchived     Boolean          @default(false)
  programBatchId String           @db.Uuid
  creator        User?            @relation(fields: [creatorId], references: [id])
  location       Location         @relation(fields: [locationId], references: [id])
  programBatch   ProgramBatch     @relation(fields: [programBatchId], references: [id])

  @@index([creatorId])
  @@index([programBatchId])
  @@index([locationId])
  @@index([uploadDate])
  @@index([visibility])
  @@index([isArchived])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([privateGroupId])
}

// ============================================================================
// MEMORY COMMENT SYSTEM
// ============================================================================

model MemoryComment {
  id        String    @id @default(uuid()) @db.Uuid
  content   String    @db.Text
  memoryId  String    @db.Uuid
  memory    Memory    @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  authorId  String    @db.Uuid
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([memoryId])
  @@index([authorId])
  @@index([createdAt])
  @@index([deletedAt])
}

// ============================================================================
// MEMORY VOTING SYSTEM
// ============================================================================

model MemoryVote {
  id        String   @id @default(uuid()) @db.Uuid
  memoryId  String   @db.Uuid
  userId    String   @db.Uuid
  createdAt DateTime @default(now())
  memory    Memory   @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([memoryId, userId])
  @@index([memoryId])
  @@index([userId])
  @@index([createdAt])
}

model Location {
  id           String   @id @default(uuid()) @db.Uuid
  buildingName String   @db.VarChar(200)
  latitude     Float
  longitude    Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  description  String?
  memories     Memory[]

  @@unique([latitude, longitude])
  @@index([buildingName])
}

model Tag {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique @db.VarChar(50)
  slug      String   @unique @db.VarChar(50)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  memories  Memory[] @relation("MemoryTags")

  @@index([name])
  @@index([slug])
}

model PrivateGroup {
  id          String       @id @default(uuid()) @db.Uuid
  name        String       @unique @db.VarChar(50)
  description String?
  creatorId   String?      @db.Uuid
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  memories    Memory[]
  creator     User?        @relation("GroupCreator", fields: [creatorId], references: [id])
  members     User[]       @relation("GroupMembers")
  invitations Invitation[]

  @@index([name])
  @@index([creatorId])
  @@index([deletedAt])
}

model Invitation {
  id        String       @id @default(uuid()) @db.Uuid
  groupId   String       @db.Uuid
  invitedBy String       @db.Uuid
  email     String       @db.VarChar(255)
  token     String       @unique @db.VarChar(64)
  expiresAt DateTime
  createdAt DateTime     @default(now())
  group     PrivateGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  inviter   User         @relation("SentInvitations", fields: [invitedBy], references: [id])

  @@index([token])
  @@index([groupId])
  @@index([email])
  @@index([expiresAt])
}

enum Status {
  STUDENT
  ALUMNI
}

enum UserRole {
  USER
  ADMIN
}

enum MemoryVisibility {
  PUBLIC
  PROGRAM_ONLY
  BATCH_ONLY
  PRIVATE
  GROUP_ONLY
}
