'use client';

import {
  Copy,
  Heart,
  Share,
  MoreHorizontal,
  Globe,
  ChevronLeft,
  ChevronRight,
} from 'lucide-react';
import { Avatar, AvatarFallback } from '@/components/ui/avatar';
import { Dialog, DialogTitle } from '@/components/ui/dialog';
import * as DialogPrimitive from '@radix-ui/react-dialog';
import type { MemoryWithCoordinates } from '@/lib/hooks/useAllMemoriesWithCoordinates';
import Image from 'next/image';
import { useState, useEffect } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import {
  coverLeftVariants,
  coverRightVariants,
  rightPageFlipVariants,
  chevronVariants,
  overlayVariants,
  PAGE_FLIP_DURATION,
  BOOK_OPEN_DURATION,
} from './memory-modal-animations';

interface MemoryDetailModalProps {
  memory: MemoryWithCoordinates | null;
  open: boolean;
  onOpenChange: (open: boolean) => void;
  onPrevious?: () => void;
  onNext?: () => void;
  hasPrevious?: boolean;
  hasNext?: boolean;
}

type ImageOrientation = 'portrait' | 'landscape' | 'square';
type AnimationPhase = 'closed' | 'opening' | 'open' | 'closing';

export function MemoryDetailModal({
  memory,
  open,
  onOpenChange,
  onPrevious,
  onNext,
  hasPrevious = false,
  hasNext = false,
}: MemoryDetailModalProps) {
  const [imageOrientation, setImageOrientation] =
    useState<ImageOrientation>('portrait');
  const [animationPhase, setAnimationPhase] =
    useState<AnimationPhase>('closed');
  const [isPageFlipped, setIsPageFlipped] = useState(false);
  const [isFlipping, setIsFlipping] = useState(false);
  // Store current and next memory for flip animation
  const [displayedMemory, setDisplayedMemory] =
    useState<MemoryWithCoordinates | null>(memory);
  const [nextMemory, setNextMemory] = useState<MemoryWithCoordinates | null>(
    null
  );

  // Sync displayed memory when not flipping
  useEffect(() => {
    if (!isFlipping && memory) {
      setDisplayedMemory(memory);
    }
  }, [memory, isFlipping]);

  // Handle open/close state changes
  useEffect(() => {
    if (open && animationPhase === 'closed') {
      setAnimationPhase('opening');
      const timer = setTimeout(() => {
        setAnimationPhase('open');
      }, BOOK_OPEN_DURATION * 1000);
      return () => clearTimeout(timer);
    } else if (!open && animationPhase === 'open') {
      setAnimationPhase('closing');
      const timer = setTimeout(() => {
        setAnimationPhase('closed');
      }, BOOK_OPEN_DURATION * 1000);
      return () => clearTimeout(timer);
    }
  }, [open, animationPhase]);

  // Reset when modal closes
  useEffect(() => {
    if (!open) {
      const timer = setTimeout(() => {
        setAnimationPhase('closed');
        setIsPageFlipped(false);
        setIsFlipping(false);
      }, 100);
      return () => clearTimeout(timer);
    }
  }, [open]);

  // Handle NEXT: right page flips over to the left
  const handleNext = () => {
    if (!hasNext || isFlipping || !onNext) return;
    setIsFlipping(true);

    // Start the flip
    setIsPageFlipped(true);

    // Halfway through flip, change content and call onNext
    setTimeout(() => {
      onNext();
    }, PAGE_FLIP_DURATION * 500);

    // After flip completes, reset page position instantly and update display
    setTimeout(() => {
      setIsPageFlipped(false);
      setIsFlipping(false);
    }, PAGE_FLIP_DURATION * 1000);
  };

  // Handle PREVIOUS: right page flips back from the left
  const handlePrevious = () => {
    if (!hasPrevious || isFlipping || !onPrevious) return;
    setIsFlipping(true);

    // For previous, we flip the page back
    // Start with page already in flipped position, then animate to flat
    setIsPageFlipped(true);

    // Immediately set to flipped, then animate back
    requestAnimationFrame(() => {
      setIsPageFlipped(false);
    });

    // Call onPrevious halfway
    setTimeout(() => {
      onPrevious();
    }, PAGE_FLIP_DURATION * 500);

    // Finish
    setTimeout(() => {
      setIsFlipping(false);
    }, PAGE_FLIP_DURATION * 1000);
  };

  if (!memory) return null;

  const createdDate = new Date(memory.createdAt || Date.now());
  const eventDate = {
    dayOfWeek: createdDate.toLocaleDateString('en-US', { weekday: 'long' }),
    month: createdDate.toLocaleDateString('en-US', { month: 'long' }),
    dayNumber: createdDate.getDate(),
  };
  const uploadTime = createdDate.toLocaleTimeString('en-US', {
    hour: '2-digit',
    minute: '2-digit',
    second: '2-digit',
    hour12: false,
  });

  // Get calendar week with full day names
  const getCalendarWeek = () => {
    const currentDay = createdDate.getDay();
    const daysLabels = ['Sun', 'Mon', 'Tue', 'Wed', 'Thur', 'Fri', 'Sat'];
    const startOfWeek = new Date(createdDate);
    startOfWeek.setDate(createdDate.getDate() - currentDay);

    return Array.from({ length: 7 }, (_, i) => {
      const day = new Date(startOfWeek);
      day.setDate(startOfWeek.getDate() + i);
      return {
        label: daysLabels[i],
        number: day.getDate(),
        active: i === currentDay,
      };
    });
  };

  // Detect image orientation on load
  const handleImageLoad = (e: React.SyntheticEvent<HTMLImageElement>) => {
    const img = e.currentTarget;
    const ratio = img.naturalWidth / img.naturalHeight;

    if (Math.abs(ratio - 1) < 0.1) {
      setImageOrientation('square');
    } else if (ratio > 1) {
      setImageOrientation('landscape');
    } else {
      setImageOrientation('portrait');
    }
  };

  // Get polaroid width based on orientation - image height is constant
  const getPolaroidWidth = () => {
    switch (imageOrientation) {
      case 'landscape':
        return 'w-full'; // full width for landscape
      case 'square':
        return 'w-72'; // 288px for square
      case 'portrait':
      default:
        return 'w-64'; // 256px for portrait
    }
  };

  const polaroidWidth = getPolaroidWidth();

  // Get author display info (creator not in current type - using placeholder)
  // TODO: Update when creator is added to MemoryWithRelations
  const authorName = 'Memory Author';
  const authorInitial = 'M';

  const mockComments = [
    {
      authorName: 'Kint Louise',
      subtitle: 'Covers collection',
      date: 'Today',
    },
  ];

  const commentCount = 120; // Mock count matching Figma

  // Use displayed memory for rendering (allows content to stay during flip)
  const mem = displayedMemory || memory;
  const memCreatedDate = new Date(mem.createdAt || Date.now());
  const memEventDate = {
    dayOfWeek: memCreatedDate.toLocaleDateString('en-US', { weekday: 'long' }),
    month: memCreatedDate.toLocaleDateString('en-US', { month: 'long' }),
    dayNumber: memCreatedDate.getDate(),
  };
  const memUploadTime = memCreatedDate.toLocaleTimeString('en-US', {
    hour: '2-digit',
    minute: '2-digit',
    second: '2-digit',
    hour12: false,
  });

  const getMemCalendarWeek = () => {
    const currentDay = memCreatedDate.getDay();
    const daysLabels = ['Sun', 'Mon', 'Tue', 'Wed', 'Thur', 'Fri', 'Sat'];
    const startOfWeek = new Date(memCreatedDate);
    startOfWeek.setDate(memCreatedDate.getDate() - currentDay);

    return Array.from({ length: 7 }, (_, i) => {
      const day = new Date(startOfWeek);
      day.setDate(startOfWeek.getDate() + i);
      return {
        label: daysLabels[i],
        number: day.getDate(),
        active: i === currentDay,
      };
    });
  };

  // LEFT PAGE CONTENT (static, doesn't animate)
  const LeftPageContent = () => (
    <div className="relative flex min-h-[600px] flex-col gap-4 rounded-xl bg-stone-50 p-6 px-10 shadow-[1px_2px_3px_0px_rgba(0,0,0,0.25)]">
      {/* Date card */}
      <div className="flex items-center justify-between rounded-xl border border-slate-200 bg-white p-4">
        <div>
          <p className="text-xs font-normal text-skolaroid-blue">WHEN</p>
          <p className="text-base font-medium text-black">
            {memEventDate.dayOfWeek}, {memEventDate.month}{' '}
            {memEventDate.dayNumber}
          </p>
          <p className="text-[8px] text-gray-400">
            {memUploadTime.replace(/:/g, '-')}
          </p>
        </div>
        {/* Calendar icon with blue top bar */}
        <div className="flex h-14 w-14 flex-col overflow-hidden rounded-md border border-slate-200 bg-gradient-to-b from-neutral-50/50 to-gray-400/50">
          <div className="h-3 w-full rounded-t-md bg-skolaroid-blue" />
          <div className="flex flex-1 items-center justify-center">
            <span className="text-2xl font-medium text-black">
              {memEventDate.dayNumber}
            </span>
          </div>
        </div>
      </div>

      {/* Polaroid-style photo */}
      <div className="flex h-96 items-center justify-center">
        <div className={`${polaroidWidth}`}>
          {mem.mediaURL ? (
            <div className="bg-white p-2 pb-8 shadow-[0px_2px_8px_2px_rgba(0,0,0,0.15)]">
              <div className="relative h-72 w-full overflow-hidden bg-gray-50">
                <Image
                  src={mem.mediaURL}
                  alt={mem.title}
                  fill
                  className="object-cover"
                  onLoad={handleImageLoad}
                />
              </div>
            </div>
          ) : (
            <div className="bg-white p-2 pb-8 shadow-[0px_2px_8px_2px_rgba(0,0,0,0.15)]">
              <div className="flex h-72 w-full items-center justify-center bg-gray-100">
                <span className="text-xs text-gray-400">No image</span>
              </div>
            </div>
          )}
        </div>
      </div>

      {/* Calendar week strip */}
      <div className="flex items-center justify-center gap-0.5">
        {getMemCalendarWeek().map((day) => (
          <div
            key={day.label + day.number}
            className="flex h-20 w-14 flex-col items-center overflow-hidden rounded bg-stone-50"
          >
            <span className="mt-1 text-[10px] text-gray-400">{day.label}</span>
            <div className="flex flex-1 items-center justify-center">
              {day.active ? (
                <div className="flex h-6 w-6 items-center justify-center rounded-full bg-skolaroid-blue">
                  <span className="text-sm font-medium text-white">
                    {day.number}
                  </span>
                </div>
              ) : (
                <span className="text-sm font-medium text-slate-700">
                  {day.number}
                </span>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  );

  // RIGHT PAGE CONTENT (this is what flips)
  const RightPageContent = () => (
    <div className="relative flex min-h-[600px] flex-col gap-4 rounded-xl bg-stone-50 p-6 px-10 shadow-[1px_2px_3px_0px_rgba(0,0,0,0.25)]">
      {/* Author info header */}
      <div className="flex items-start gap-3">
        <Avatar className="h-9 w-9">
          <AvatarFallback className="bg-zinc-300 text-sm text-slate-600">
            {authorInitial}
          </AvatarFallback>
        </Avatar>
        <div className="flex-1">
          <p className="text-sm font-semibold text-slate-800">{authorName}</p>
          <div className="flex items-center gap-1 text-xs text-gray-400">
            <Globe className="h-3 w-3" />
            <span>Public</span>
          </div>
        </div>
        <button
          className="text-gray-400 hover:text-slate-600"
          aria-label="More options"
        >
          <MoreHorizontal className="h-5 w-5" />
        </button>
      </div>

      {/* Caption card */}
      <div className="rounded-2xl bg-gradient-to-b from-slate-100 to-gray-100 p-5 shadow-[0px_1px_2px_0.5px_rgba(0,0,0,0.25)] outline outline-[3px] outline-white">
        <p className="text-center font-dancing text-2xl leading-relaxed text-slate-800">
          {mem.description || 'A memorable moment...'}
        </p>
      </div>

      {/* Action icons */}
      <div className="flex items-center justify-center gap-4">
        <button
          className="text-slate-600 hover:text-slate-800"
          aria-label="Copy"
        >
          <Copy className="h-5 w-5" />
        </button>
        <button
          className="text-slate-600 hover:text-slate-800"
          aria-label="Like"
        >
          <Heart className="h-5 w-5" />
        </button>
        <button
          className="text-slate-600 hover:text-slate-800"
          aria-label="Share"
        >
          <Share className="h-5 w-5" />
        </button>
      </div>

      {/* Comments section */}
      <div>
        <div className="mb-2 flex items-center gap-2">
          <h3 className="text-base font-medium text-black">Comments</h3>
          <span className="rounded-lg bg-gray-200 px-2 py-0.5 text-sm font-medium text-black">
            {commentCount}
          </span>
        </div>

        <div className="flex max-h-32 flex-col gap-3 overflow-y-auto pr-1">
          {mockComments.map((comment, idx) => (
            <div key={idx} className="flex items-start gap-2">
              <Avatar className="h-9 w-9">
                <AvatarFallback className="bg-zinc-300 text-sm text-slate-600">
                  {comment.authorName.charAt(0)}
                </AvatarFallback>
              </Avatar>
              <div className="flex-1">
                <div className="flex items-center justify-between">
                  <p className="text-sm font-semibold text-slate-800">
                    {comment.authorName}
                  </p>
                  <span className="text-xs text-gray-400">{comment.date}</span>
                </div>
                <p className="text-sm text-slate-800">{comment.subtitle}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  );

  // BACK OF RIGHT PAGE (shown when page is flipped over)
  const RightPageBack = () => (
    <div
      className="absolute inset-0 flex min-h-[600px] items-center justify-center rounded-xl bg-stone-100 shadow-[1px_2px_3px_0px_rgba(0,0,0,0.25)]"
      style={{ transform: 'rotateY(180deg)', backfaceVisibility: 'hidden' }}
    >
      <p className="text-sm text-gray-400">Page back</p>
    </div>
  );

  return (
    <Dialog open={open} onOpenChange={onOpenChange}>
      <AnimatePresence>
        {open && (
          <DialogPrimitive.Portal forceMount>
            {/* Animated overlay */}
            <motion.div
              className="fixed inset-0 z-50 bg-black/50"
              variants={overlayVariants}
              initial="closed"
              animate="open"
              exit="closed"
            />

            {/* Main content container with chevrons */}
            <DialogPrimitive.Content asChild forceMount>
              <div
                className="fixed left-1/2 top-1/2 z-50 flex items-center gap-6"
                style={{
                  transform: 'translate(-50%, -50%)',
                  perspective: '2000px',
                }}
              >
                <DialogTitle className="sr-only">{memory.title}</DialogTitle>

                {/* Left chevron navigation */}
                <motion.button
                  onClick={handlePrevious}
                  disabled={!hasPrevious || isFlipping}
                  className="flex h-12 w-12 items-center justify-center rounded-full bg-white/90 text-slate-700 shadow-lg backdrop-blur-sm transition-colors hover:bg-white disabled:cursor-not-allowed disabled:opacity-30"
                  variants={chevronVariants}
                  initial="idle"
                  whileHover={hasPrevious ? 'hover' : 'disabled'}
                  whileTap={hasPrevious ? 'tap' : 'disabled'}
                  aria-label="Previous memory"
                >
                  <ChevronLeft className="h-6 w-6" />
                </motion.button>

                {/* Book container */}
                <div
                  className="relative"
                  style={{
                    width: '968px',
                    transformStyle: 'preserve-3d',
                  }}
                >
                  {/* ===== BOOK PAGES (always visible behind covers) ===== */}
                  <div className="relative rounded-2xl bg-sky-200 p-2 shadow-[0px_2px_4px_0px_rgba(0,0,0,0.25)]">
                    {/* Notebook title tab */}
                    <div className="absolute -top-5 left-3 z-30 rounded-t-md bg-sky-200 px-3 py-0.5">
                      <span className="text-[10px] text-slate-600">
                        {mem.location?.buildingName || 'Memory'}
                      </span>
                    </div>

                    {/* Pages grid container */}
                    <div
                      className="relative grid grid-cols-2 gap-3"
                      style={{ transformStyle: 'preserve-3d' }}
                    >
                      {/* LEFT PAGE (static) */}
                      <LeftPageContent />

                      {/* SPINE / RINGS */}
                      <div className="pointer-events-none absolute inset-y-0 left-1/2 z-20 flex w-14 -translate-x-1/2 flex-col items-center justify-around py-4">
                        {[0, 1, 2].map((i) => (
                          <div
                            key={i}
                            className="relative flex h-4 w-14 items-center justify-center"
                          >
                            <div className="absolute left-0.5 h-3.5 w-3.5 rounded-full bg-black" />
                            <div className="absolute right-0.5 h-3.5 w-3.5 rounded-full bg-black" />
                            <div className="relative z-10 h-1.5 w-10 rounded bg-zinc-400" />
                          </div>
                        ))}
                      </div>

                      {/* RIGHT PAGE (animated - flips like a book page) */}
                      <motion.div
                        className="relative"
                        style={{
                          transformStyle: 'preserve-3d',
                          transformOrigin: 'left center',
                        }}
                        variants={rightPageFlipVariants}
                        animate={isPageFlipped ? 'flipped' : 'flat'}
                      >
                        {/* Front of page */}
                        <div style={{ backfaceVisibility: 'hidden' }}>
                          <RightPageContent />
                        </div>
                        {/* Back of page */}
                        <RightPageBack />
                      </motion.div>
                    </div>
                  </div>

                  {/* ===== BOOK COVERS (only show during opening/closing) ===== */}
                  {animationPhase !== 'open' && (
                    <>
                      {/* Left cover - hinged on right edge */}
                      <motion.div
                        className="absolute inset-0 rounded-l-2xl bg-sky-200 shadow-[0px_4px_8px_0px_rgba(0,0,0,0.3)]"
                        style={{
                          width: '50%',
                          transformOrigin: 'right center',
                          transformStyle: 'preserve-3d',
                          backfaceVisibility: 'hidden',
                        }}
                        variants={coverLeftVariants}
                        initial="closed"
                        animate={animationPhase}
                      >
                        {/* Cover front */}
                        <div className="flex h-full items-center justify-center rounded-l-2xl bg-sky-200">
                          <div className="flex flex-col items-center gap-2">
                            <div className="h-24 w-1 rounded-full bg-sky-300" />
                            <p className="text-xs text-sky-400">Memories</p>
                          </div>
                        </div>
                        {/* Cover back (inside of cover) */}
                        <div
                          className="absolute inset-0 rounded-r-2xl bg-sky-100"
                          style={{
                            transform: 'rotateY(180deg)',
                            backfaceVisibility: 'hidden',
                          }}
                        />
                      </motion.div>

                      {/* Right cover - hinged on left edge */}
                      <motion.div
                        className="absolute inset-0 left-1/2 rounded-r-2xl bg-sky-200 shadow-[0px_4px_8px_0px_rgba(0,0,0,0.3)]"
                        style={{
                          width: '50%',
                          transformOrigin: 'left center',
                          transformStyle: 'preserve-3d',
                          backfaceVisibility: 'hidden',
                        }}
                        variants={coverRightVariants}
                        initial="closed"
                        animate={animationPhase}
                      >
                        {/* Cover front */}
                        <div className="flex h-full items-center justify-center rounded-r-2xl bg-sky-200">
                          <div className="flex flex-col items-center gap-2">
                            <div className="h-24 w-1 rounded-full bg-sky-300" />
                            <p className="text-xs text-sky-400">Book</p>
                          </div>
                        </div>
                        {/* Cover back (inside of cover) */}
                        <div
                          className="absolute inset-0 rounded-l-2xl bg-sky-100"
                          style={{
                            transform: 'rotateY(180deg)',
                            backfaceVisibility: 'hidden',
                          }}
                        />
                      </motion.div>
                    </>
                  )}
                </div>

                {/* Right chevron navigation */}
                <motion.button
                  onClick={handleNext}
                  disabled={!hasNext || isFlipping}
                  className="flex h-12 w-12 items-center justify-center rounded-full bg-white/90 text-slate-700 shadow-lg backdrop-blur-sm transition-colors hover:bg-white disabled:cursor-not-allowed disabled:opacity-30"
                  variants={chevronVariants}
                  initial="idle"
                  whileHover={hasNext ? 'hover' : 'disabled'}
                  whileTap={hasNext ? 'tap' : 'disabled'}
                  aria-label="Next memory"
                >
                  <ChevronRight className="h-6 w-6" />
                </motion.button>
              </div>
            </DialogPrimitive.Content>
          </DialogPrimitive.Portal>
        )}
      </AnimatePresence>
    </Dialog>
  );
}
